<!--
  ============================================================
  ひかり電話HGW 向け sofia external プロファイル + ゲートウェイ
  旧 Asterisk PJSIP トランク（asterisk_templates/pjsip.conf.j2）からの翻訳。
  プレースホルダ __XXX__ は entrypoint が .env 値で置換する。
  ============================================================
-->
<profile name="external">
  <gateways>
    <!--
      HGW ゲートウェイ。
      ひかり電話HGWの癖:
        * realm/from-domain/proxy は FQDNではなく HGWのLAN側IP。
        * username(認証ID) = 内線番号。
        * UDPのみ。register-transport=udp を明示。
        * 発信者番号は最終的にHGWが決定（caller-id-in-fromは表示/ログ用途）。
    -->
    <gateway name="hgw">
      <!-- 認証: 旧 type=auth (userpass)。username=内線番号 -->
      <param name="username"           value="__HGW_SIP_USER__"/>
      <param name="password"           value="__HGW_SIP_PASSWORD__"/>

      <!-- ドメイン/プロキシ: 旧 server_uri / from_domain = HGW IP -->
      <param name="realm"              value="__HGW_IP__"/>
      <param name="proxy"              value="__HGW_IP__"/>
      <param name="register-proxy"     value="__HGW_IP__"/>
      <param name="from-domain"        value="__HGW_IP__"/>

      <!-- From/Contact の user部 = 内線番号 (旧 from_user / contact_user) -->
      <param name="from-user"          value="__HGW_SIP_USER__"/>
      <!-- 着信 INVITE の request-uri user が内線番号で来る想定 -->
      <param name="extension"          value="__HGW_SIP_USER__"/>

      <!-- 登録: 旧 expiration=3600 / retry_interval=60(→30に短縮) -->
      <param name="register"           value="true"/>
      <param name="register-transport" value="udp"/>
      <param name="expire-seconds"     value="3600"/>
      <param name="retry-seconds"      value="30"/>

      <!-- 発信者番号(自局番号)通知: 旧 send_pai/send_rpid/trust_id_inbound 相当 -->
      <param name="caller-id-in-from"  value="true"/>

      <!--
        OPTIONS キープアライブ(旧 qualify 相当)。
        HGWが OPTIONS に応答しない個体では、通話は通るのに gateway が DOWN と
        表示される。その場合は value を 0 にして判定すること。
      -->
      <param name="ping"               value="30"/>

      <!-- 着信をこのコンテキストへ -->
      <param name="context"            value="public"/>
    </gateway>
  </gateways>

  <domains>
    <domain name="all" alias="false" parse="true"/>
  </domains>

  <settings>
    <!-- 着信コンテキスト -->
    <param name="context"                    value="public"/>

    <!-- UDP/5060 で待受（internal.xml は entrypoint が削除済み） -->
    <param name="sip-port"                   value="5060"/>
    <!--
      待受/RTP IP は host network 上のプライマリLAN IP を自動採用。
      注意: ホストに複数NICがあり別セグメントが選ばれると音声片方向になる。
      その場合は $${local_ip_v4} を実LAN IP（HGWと同一セグメント）に置換する。
    -->
    <param name="sip-ip"                     value="$${local_ip_v4}"/>
    <param name="rtp-ip"                     value="$${local_ip_v4}"/>
    <!--
      同一LANのためNATなし。ext-sip-ip/ext-rtp-ip は設定しない。
      （グローバルIP等を入れるとSDPのcが誤りになり音声片方向の原因になる）
    -->

    <!-- コーデック: 旧 allow=ulaw/alaw。日本のPSTNは µ-law 主 -->
    <param name="inbound-codec-prefs"        value="PCMU,PCMA"/>
    <param name="outbound-codec-prefs"       value="PCMU,PCMA"/>
    <param name="inbound-codec-negotiation"  value="generous"/>

    <!-- DTMF: RFC2833(telephone-event)。HGW標準 -->
    <param name="dtmf-type"                  value="rfc2833"/>

    <!--
      Session-Timers 無効化。ひかり電話HGWはUPDATEベースの
      セッションタイマーで通話が途中切断・不安定になる報告があるため
      スパイクは無効で開始する（必要なら true に戻して再検証）。
    -->
    <param name="enable-timer"               value="false"/>

    <!-- 着信INVITEは無認証で受理(旧 type=identify 相当)。使い捨て検証用 -->
    <param name="auth-calls"                 value="false"/>
    <param name="apply-inbound-acl"          value="none"/>

    <!-- メディアはFS経由(echo双方向検証に必須)。bypass-media は設定しない -->
    <param name="inbound-late-negotiation"   value="true"/>
    <param name="manage-presence"            value="false"/>

    <!-- RTPタイマ -->
    <param name="rtp-timer-name"             value="soft"/>
    <param name="rtp-timeout-sec"            value="300"/>
    <param name="rtp-hold-timeout-sec"       value="1800"/>
  </settings>
</profile>
