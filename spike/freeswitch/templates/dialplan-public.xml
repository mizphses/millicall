<!--
  ============================================================
  着信テスト用 dialplan（public コンテキスト）
  HGWからの着信をすべて捕捉し、双方向音声(RTP)が通ることを echo で確認する。
  流れ: answer → 0.5秒待ち → 確認トーン2秒 → echo（発話が自分に返れば双方向OK）
  ============================================================
-->
<include>
  <context name="public">
    <extension name="hgw_inbound_test">
      <condition field="destination_number" expression="^(.*)$">
        <action application="log"      data="INFO ===== HGW INBOUND: from=${caller_id_number} to=${destination_number} ====="/>
        <action application="answer"/>
        <action application="sleep"    data="500"/>
        <!-- 400Hz系の確認トーンを2秒（応答確認。日本の可聴トーン帯） -->
        <action application="playback" data="tone_stream://%(2000,500,440,480)"/>
        <!-- echo: 相手の声をそのまま返す。受話器で自分の声が聞こえれば双方向RTP成立 -->
        <action application="echo"/>
      </condition>
    </extension>
  </context>
</include>
