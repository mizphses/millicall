# ============================================================
# millicall v2 / Phase 0 HGWスパイク 環境変数サンプル
# 使い方: cp .env.example .env && chmod 600 .env で編集
# .env は絶対にコミットしない（spike/.gitignore で除外済み）
# ============================================================

# ひかり電話HGWのLAN側IPアドレス。
# HGWの管理画面に表示される「LAN側IPアドレス」。多くは 192.168.1.1。
# realm / from-domain / proxy / register-proxy にそのまま使われる（FQDNではなくIP）。
HGW_IP=192.168.1.1

# HGWに登録したSIP内線の「内線番号」= SIP認証ユーザー名。
# HGWの「内線設定」で発行した番号（例: 1, 2, ... または 3桁の内線ID）。
HGW_SIP_USER=1

# 上記内線のSIP認証パスワード（HGWの内線設定で設定したもの）。
HGW_SIP_PASSWORD=changeme

# 発信時にFreeSWITCH側で付与する発信者番号（自局の契約電話番号、ハイフンなし）。
# 表示・ログ用。実際に相手に通知される番号は最終的にHGWが決定する。
OUTBOUND_CALLERID=0312345678
