{#
  【外線着信 = 内線への自動転送】
  トランクごとに inbound_extension（着信転送先の内線番号）を持つ。
  ひかり電話HGWでは着信INVITEのdestination_numberはDID（公開番号）ではなく
  HGWの内線設定で登録された番号（trunk.username）が届くため、
  username / did_number のどちらに一致しても同じトランクの着信とみなし、
  default コンテキストの inbound_extension へ transfer する。
  転送先の実体（電話機/AIエージェント/ワークフロー/グループ着信）の解決は
  default コンテキスト側の統一番号プランに委ねる。
#}
<include>
  <context name="public">
{#
  匿名着信拒否オプション (Phase 6 Task 7):
  sip_reject_anonymous=True のとき、caller-ID が anonymous/restricted/空の呼を
  CALL_REJECTED で拒否する extension をコンテキスト先頭に挿入する。
  !! 重要: デフォルト False !!
  NTT ひかり電話 HGW 回線は 186 プレフィックス未付与時に caller-ID が非通知になるため、
  True にすると実機着信がすべて拒否される。本番では絶対に True にしないこと。
  186プレフィックス付き（caller-ID あり）の呼はこの extension にマッチしないため通過する。
#}
{% if sip_reject_anonymous %}
    <extension name="reject_anonymous" continue="false">
      <condition field="${caller_id_number}" expression="^(anonymous|restricted|Anonymous|)$">
        <action application="log" data="WARNING ===== ANONYMOUS CALL REJECTED: ${caller_id_number} ====="/>
        <action application="hangup" data="CALL_REJECTED"/>
      </condition>
    </extension>
{% endif %}
{% for trunk in trunks %}
{% if trunk.inbound_extension %}
    <extension name="inbound_trunk_{{ trunk.name }}">
      <condition field="destination_number" expression="^({{ trunk.username | re_escape }}{% if trunk.did_number and trunk.did_number != trunk.username %}|{{ trunk.did_number | re_escape }}{% endif %})$">
        <action application="log" data="INFO ===== INBOUND trunk {{ trunk.name }} -> ext {{ trunk.inbound_extension }} ====="/>
        <action application="transfer" data="{{ trunk.inbound_extension }} XML default"/>
      </condition>
    </extension>
{% endif %}
{% endfor %}
    <extension name="inbound_no_route">
      <condition field="destination_number" expression="^(.*)$">
        <action application="log" data="WARNING ===== INBOUND NO ROUTE: ${destination_number} ====="/>
        <action application="hangup" data="NO_ROUTE_DESTINATION"/>
      </condition>
    </extension>
  </context>
</include>
