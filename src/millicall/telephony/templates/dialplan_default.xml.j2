<include>
  <context name="default">
{#
  【統一番号プラン】順序が重要:
    1. グループ着信（一斉鳴動） 2. AIエージェント 3. ワークフロー 4. 汎用（電話機）
  1〜3 に一致しない 2〜6 桁のみ 4 の bridge user/N に到達する。
  外線着信も public コンテキストから transfer でここに入るため、
  内線発信・外線着信のどちらも同じ番号解決になる。
#}
{% for group in ring_groups %}
{% if group.member_numbers %}
    <extension name="ring_group_{{ group.number }}">
      <condition field="destination_number" expression="^{{ group.number | re_escape }}$">
        <action application="log" data="INFO ===== RING GROUP {{ group.number }} ({{ group.member_numbers | length }} members) ====="/>
        <action application="set" data="ignore_early_media=true"/>
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="bridge" data="{% for m in group.member_numbers %}user/{{ m }}@{{ internal_domain }}{% if not loop.last %},{% endif %}{% endfor %}"/>
        <action application="hangup" data="NO_ANSWER"/>
      </condition>
    </extension>
{% endif %}
{% endfor %}
{% for agent in ai_agents %}
    <extension name="ai_agent_{{ agent.number }}">
      <condition field="destination_number" expression="^{{ agent.number | re_escape }}$">
        <action application="log" data="INFO ===== AI AGENT {{ agent.number }} -> agent {{ agent.agent_id }} ====="/>
        {#- verbose_events は必須: CHANNEL_ANSWER に variable_millicall_ai_agent を載せるため -#}
        <action application="set" data="verbose_events=true"/>
        <action application="set" data="millicall_ai_agent={{ agent.agent_id }}"/>
        <action application="answer"/>
        <action application="park"/>
      </condition>
    </extension>
{% endfor %}
{% for wf in workflows %}
    <extension name="workflow_{{ wf.number }}">
      <condition field="destination_number" expression="^{{ wf.number | re_escape }}$">
        <action application="log" data="INFO ===== WORKFLOW {{ wf.number }} -> workflow {{ wf.workflow_id }} ====="/>
        <action application="set" data="verbose_events=true"/>
        <action application="set" data="millicall_workflow={{ wf.workflow_id }}"/>
        {% if wf.ring_count > 0 %}
        <action application="ring_ready"/>
        <action application="sleep" data="{{ wf.ring_count * 6000 }}"/>
        {% endif %}
        <action application="answer"/>
        {#- external プロファイルは HGW 互換のため RFC2833 無効（dtmf-type=none）。
            外線 DTMF はインバンドのみなので spandsp のインバンド検出を起動する。 -#}
        <action application="start_dtmf"/>
        <action application="park"/>
      </condition>
    </extension>
{% endfor %}
    <extension name="internal_extensions">
      <condition field="destination_number" expression="^(\d{2,6})$">
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="set" data="continue_on_fail=true"/>
        <action application="bridge" data="user/${destination_number}@{{ internal_domain }}"/>
        <action application="hangup" data="NO_ROUTE_DESTINATION"/>
      </condition>
    </extension>
{% if outbound_trunk %}
    <!--
      発信権限ゲート（トールフラウド対策 §7）
      チャンネル変数 ${calling_permission} はディレクトリの <variable> で内線ごとに設定される。
      - "international": 国際発信可（global allowlist との AND 条件）
      - "domestic"     : 国内 PSTN まで（デフォルト）
      - "internal"     : 内線のみ（国内 PSTN も不可）
    -->

    <!-- 国際発信 allowlist: "international" 権限かつ allowlist 一致の場合のみ通過 -->
{% for prefix in international_allow_prefixes %}
    <extension name="outbound_intl_allow_{{ prefix }}">
      <condition field="destination_number" expression="^({{ prefix }}\d+)$">
        <condition field="${calling_permission}" expression="^international$">
          <action application="set" data="effective_caller_id_number={{ outbound_trunk.caller_id }}"/>
          <action application="set" data="effective_caller_id_name={{ outbound_trunk.caller_id }}"/>
          <action application="set" data="hangup_after_bridge=true"/>
          <action application="bridge" data="sofia/gateway/{{ outbound_trunk.name }}/${destination_number}"/>
          <action application="hangup"/>
          <anti-action application="log" data="WARNING calling_permission=${calling_permission} INTL_REJECTED: ${destination_number}"/>
          <anti-action application="hangup" data="CALL_REJECTED"/>
        </condition>
      </condition>
    </extension>
{% endfor %}
    <!-- 国際番号バックストップ: allowlist 外または権限不足を無条件ブロック -->
    <extension name="outbound_intl_block">
      <condition field="destination_number" expression="^(010\d+|00[1-9]\d+)$">
        <action application="log" data="WARNING ===== INTL BLOCKED: ${destination_number} calling_permission=${calling_permission} ====="/>
        <action application="hangup" data="CALL_REJECTED"/>
      </condition>
    </extension>
    <!--
      国内 PSTN 発信: "domestic" または "international" 権限の場合のみ通過させる。
      "internal" 権限の内線は CALL_REJECTED で拒否（トールフラウド対策）。
    -->
    <extension name="outbound_external">
      <condition field="destination_number" expression="^(0\d+)$">
        <condition field="${calling_permission}" expression="^(domestic|international)$">
          <action application="set" data="effective_caller_id_number={{ outbound_trunk.caller_id }}"/>
          <action application="set" data="effective_caller_id_name={{ outbound_trunk.caller_id }}"/>
          <action application="set" data="hangup_after_bridge=true"/>
          <action application="bridge" data="sofia/gateway/{{ outbound_trunk.name }}/${destination_number}"/>
          <action application="hangup"/>
          <anti-action application="log" data="WARNING calling_permission=${calling_permission} DOMESTIC_REJECTED: ${destination_number}"/>
          <anti-action application="hangup" data="CALL_REJECTED"/>
        </condition>
      </condition>
    </extension>
{% endif %}
  </context>
</include>
