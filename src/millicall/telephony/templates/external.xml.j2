<!--
  ============================================================
  sofia external profile + per-trunk gateway
  Generated by FreeswitchConfigWriter — DO NOT EDIT BY HAND.

  DISPATCH NOTE: sip-port={{ external_sip_port }} (co-existence with internal:5060)
  is NOT yet proven against a real HGW.  The spike proved external-alone on 5060.
  The fallback plan lives in the Phase 2 RUNBOOK.
  ============================================================
-->
<profile name="external">
  <gateways>
{% for trunk in trunks %}
    <gateway name="{{ trunk.name }}">
      <param name="username"           value="{{ trunk.username }}"/>
      <param name="password"           value="{{ trunk.password }}"/>
      <param name="realm"              value="{{ trunk.host }}"/>
      <param name="proxy"              value="{{ trunk.host }}"/>
      <param name="register-proxy"     value="{{ trunk.host }}"/>
      <param name="from-domain"        value="{{ trunk.host }}"/>
      <param name="from-user"          value="{{ trunk.username }}"/>
      <param name="extension"          value="{{ trunk.username }}"/>
      <param name="register"           value="true"/>
      <param name="register-transport" value="udp"/>
      <param name="expire-seconds"     value="3600"/>
      <param name="retry-seconds"      value="30"/>
      <param name="caller-id-in-from"  value="true"/>
      <param name="ping"               value="30"/>
      <param name="context"            value="public"/>
    </gateway>
{% endfor %}
  </gateways>

  <domains>
    <domain name="all" alias="false" parse="true"/>
  </domains>

  <settings>
    <param name="context"                    value="public"/>
    <param name="sip-port"                   value="{{ external_sip_port }}"/>
    <param name="sip-ip"                     value="{{ sip_bind_ip if sip_bind_ip is not none else sip_ip }}"/>
    <param name="rtp-ip"                     value="{{ sip_bind_ip if sip_bind_ip is not none else rtp_ip }}"/>
    <param name="inbound-codec-prefs"        value="PCMU,PCMA"/>
    <param name="outbound-codec-prefs"       value="PCMU,PCMA"/>
    <param name="inbound-codec-negotiation"  value="generous"/>
    <!--
      DTMF: RFC2833 を完全無効化（実機検証 2026-07-05 で確定）。
      HGW は SDP answer がオファーの部分集合であることを厳格に要求し
      (RFC 3264)、オファーに無い telephone-event(101) を answer に含めると
      ACK 直後(約90ms)に BYE で切断される。dtmf-type=none 単独では
      SDP 広告が消えないため rfc2833-pt=0 が必須。
    -->
    <param name="dtmf-type"                  value="none"/>
    <param name="rfc2833-pt"                 value="0"/>
    <!--
      Session-Timers 有効（実機検証 2026-07-05 で確認）。
      HGW は INVITE で Session-Expires: 300 を要求する。
    -->
    <param name="enable-timer"               value="true"/>
    <param name="auth-calls"                 value="false"/>
    <!-- SIP多層防御: HGW (192.168.1.1) は192.168.0.0/16に内包され通過する。WAN任意送信元は拒否。-->
    <param name="apply-inbound-acl"          value="millicall_trusted"/>
    <param name="inbound-late-negotiation"   value="true"/>
    <param name="manage-presence"            value="false"/>
    <param name="rtp-timer-name"             value="soft"/>
    <param name="rtp-timeout-sec"            value="300"/>
    <param name="rtp-hold-timeout-sec"       value="1800"/>
  </settings>
</profile>
