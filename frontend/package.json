{
  "name": "millicall-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "vite",
    "gen:api": "cd .. && uv run python scripts/gen-openapi.py > frontend/src/api/openapi.json && cd frontend && openapi-typescript src/api/openapi.json -o src/api/schema.d.ts",
    "build": "panda codegen && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.87.0",
    "@xyflow/react": "^12.11.2",
    "lucide-react": "^1.23.0",
    "openapi-fetch": "^0.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@pandacss/dev": "^0.53.0",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
