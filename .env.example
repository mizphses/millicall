# FreeSWITCH / core の内線ドメイン。RUNBOOK ではサーバの LAN IP を設定すること。
MILLICALL_SIP_DOMAIN=192.168.1.10
# core が待受けるデータディレクトリ（コンテナ内 /app/data、ホスト ./data にマウント）
MILLICALL_DATA_DIR=/app/data
MILLICALL_DATABASE_URL=sqlite+aiosqlite:////app/data/millicall.db
MILLICALL_FS_CONFIG_DIR=/app/data/freeswitch
# host network 上で core と freeswitch は同一 127.0.0.1 を共有
MILLICALL_ESL_HOST=127.0.0.1
MILLICALL_ESL_PORT=8021
MILLICALL_EVENT_SOCKET_IP=127.0.0.1
# 本番は true（HTTPS 前提）。LAN内 HTTP 検証時のみ false。
MILLICALL_COOKIE_SECURE=false
# プリビルドイメージのタグ (deploy/docker-compose.prod.yml 用。latest / dev / vX.Y.Z)
# MILLICALL_VERSION=latest
